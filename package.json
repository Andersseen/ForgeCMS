{
  "name": "forge-cms",
  "version": "0.0.0",
  "private": true,
  "description": "An experimental Payload-like CMS foundation for Angular and Analog.js developers.",
  "author": "ForgeCMS contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forge-cms/forge-cms.git"
  },
  "bugs": {
    "url": "https://github.com/forge-cms/forge-cms/issues"
  },
  "homepage": "https://github.com/forge-cms/forge-cms#readme",
  "keywords": [
    "cms",
    "angular",
    "analogjs",
    "typescript",
    "turborepo",
    "payload",
    "cloudflare",
    "headless-cms"
  ],
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:playground": "pnpm --filter @forge-cms/playground dev",
    "build": "turbo run build",
    "build:playground": "pnpm --filter @forge-cms/playground build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:playground": "pnpm --filter @forge-cms/playground test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf .turbo dist coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.33.1",
    "vite": "^7.1.4",
    "vitest": "^4.1.6"
  }
}
