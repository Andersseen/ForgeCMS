{
  "name": "@devflare-cms/playground",
  "version": "0.0.0",
  "private": true,
  "description": "Analog.js playground for Devflare CMS.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "test": "vitest run --dir .",
    "test:watch": "vitest --dir .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .analog coverage"
  },
  "dependencies": {
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/platform-browser": "^21.2.10",
    "@devflare-cms/core": "workspace:*",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/compiler-cli": "^21.2.10",
    "@analogjs/vite-plugin-angular": "^2.4.8",
    "jsdom": "^27.3.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
