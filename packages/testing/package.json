{
  "name": "@forge-cms/testing",
  "version": "0.0.0",
  "description": "Shared testing helpers for ForgeCMS packages.",
  "author": "ForgeCMS contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forge-cms/forge-cms.git",
    "directory": "packages/testing"
  },
  "bugs": {
    "url": "https://github.com/forge-cms/forge-cms/issues"
  },
  "homepage": "https://github.com/forge-cms/forge-cms/tree/main/packages/testing#readme",
  "keywords": [
    "cms",
    "testing",
    "vitest",
    "typescript"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "types": "./src/contracts/index.ts",
      "default": "./src/contracts/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --dir .",
    "test:watch": "vitest --dir .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@forge-cms/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
